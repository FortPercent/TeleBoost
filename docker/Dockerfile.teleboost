# ============================================================
# TeleBoost — single-file Dockerfile
# ============================================================
# Builds a self-contained image: NGC PyTorch 24.08 base, then layered
# torch 2.6 + vllm 0.8.4 + flash-attn 2.7.4.post1 + flashinfer 0.2.2.post1,
# upstream verl v0.4.0 (no-deps), Wan + reward dependencies, hpsv2 packaging
# fixes, and the TeleBoost source as an editable install.
#
# Build:
#   cd /path/to/TeleBoost
#   docker build -f docker/Dockerfile.teleboost -t teleboost/teleboost:latest .
#
# China-mirror build (Tsinghua):
#   docker build -f docker/Dockerfile.teleboost \
#     --build-arg APT_SOURCE=https://mirrors.tuna.tsinghua.edu.cn/ubuntu/ \
#     --build-arg PIP_INDEX=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple \
#     -t teleboost/teleboost:latest .
#
# Run (4×H100, mount your own data):
#   docker run --rm --gpus all --ipc=host --shm-size=32g \
#     -v $PWD:/workspace/TeleBoost \
#     -e TORCH_COMPILE_DISABLE=1 \
#     teleboost/teleboost:latest \
#     bash recipe/teleboost/run_teleboost.sh
# ============================================================

# NGC PyTorch 24.08: Ubuntu 22.04 + CUDA 12.6 + Python 3.10 + torch 2.5 + TE 1.9
# https://docs.nvidia.com/deeplearning/frameworks/pytorch-release-notes/rel-24-08.html
FROM nvcr.io/nvidia/pytorch:24.08-py3

# ---------- base env ----------
ENV MAX_JOBS=32 \
    VLLM_WORKER_MULTIPROC_METHOD=spawn \
    DEBIAN_FRONTEND=noninteractive \
    NODE_OPTIONS="" \
    PIP_ROOT_USER_ACTION=ignore \
    HF_HUB_ENABLE_HF_TRANSFER="1"

# Default to the standard upstream apt + pip endpoints. Override with
# `--build-arg APT_SOURCE=...  --build-arg PIP_INDEX=...` for region mirrors.
ARG APT_SOURCE=
ARG PIP_INDEX=

# ---------- apt: optional mirror + system tools ----------
# python3-tk works around hpsv2 importing tkinter via dead `from turtle import forward`
# ffmpeg: video I/O for the videophy reward
RUN if [ -n "${APT_SOURCE}" ]; then \
        cp /etc/apt/sources.list /etc/apt/sources.list.bak && \
        { \
        echo "deb ${APT_SOURCE} jammy main restricted universe multiverse"; \
        echo "deb ${APT_SOURCE} jammy-updates main restricted universe multiverse"; \
        echo "deb ${APT_SOURCE} jammy-backports main restricted universe multiverse"; \
        echo "deb ${APT_SOURCE} jammy-security main restricted universe multiverse"; \
        } > /etc/apt/sources.list ; \
    fi && \
    apt-get update && \
    apt-get install -y --no-install-recommends -o Dpkg::Options::="--force-confdef" \
        systemd tini \
        python3-tk \
        ffmpeg \
        git curl wget && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# ---------- pip: optional mirror + upgrade ----------
RUN if [ -n "${PIP_INDEX}" ]; then \
        pip config set global.index-url "${PIP_INDEX}" && \
        pip config set global.extra-index-url "${PIP_INDEX}" ; \
    fi && \
    python -m pip install --upgrade pip

# ---------- drop NGC's bundled torch 2.5 fork; we need torch 2.6 for vllm 0.8.4 ----------
RUN pip uninstall -y torch torchvision torchaudio \
    pytorch-quantization pytorch-triton torch-tensorrt \
    xgboost transformer_engine flash_attn apex megatron-core grpcio || true && \
    rm -rf /usr/local/lib/python3.10/dist-packages/cv2

# ---------- core: vllm 0.8.4 + torch 2.6 + RL stack ----------
RUN pip install --no-cache-dir \
    "vllm==0.8.4" "torch==2.6.0" "torchvision==0.21.0" "torchaudio==2.6.0" "tensordict==0.6.2" torchdata \
    "transformers[hf_xet]==4.57.1" accelerate datasets peft hf-transfer \
    "numpy<2.0.0" "pyarrow>=15.0.0" pandas \
    ray[default] codetiming hydra-core pylatexenc qwen-vl-utils wandb dill pybind11 liger-kernel mathruler \
    pytest py-spy pyext pre-commit ruff \
    tensorboard fastapi uvicorn

# ---------- flash-attn 2.7.4.post1 ----------
RUN wget -nv https://github.com/Dao-AILab/flash-attention/releases/download/v2.7.4.post1/flash_attn-2.7.4.post1+cu12torch2.6cxx11abiFALSE-cp310-cp310-linux_x86_64.whl && \
    pip install --no-cache-dir flash_attn-2.7.4.post1+cu12torch2.6cxx11abiFALSE-cp310-cp310-linux_x86_64.whl && \
    rm -f flash_attn-2.7.4.post1+cu12torch2.6cxx11abiFALSE-cp310-cp310-linux_x86_64.whl

# ---------- flashinfer 0.2.2.post1 (vllm 0.8.x doesn't support >=0.2.3) ----------
RUN wget -nv https://github.com/flashinfer-ai/flashinfer/releases/download/v0.2.2.post1/flashinfer_python-0.2.2.post1+cu124torch2.6-cp38-abi3-linux_x86_64.whl && \
    pip install --no-cache-dir flashinfer_python-0.2.2.post1+cu124torch2.6-cp38-abi3-linux_x86_64.whl && \
    rm -f flashinfer_python-0.2.2.post1+cu124torch2.6-cp38-abi3-linux_x86_64.whl

# ---------- pinned NV/FastAPI/etc fixups ----------
RUN pip uninstall -y pynvml nvidia-ml-py && \
    pip install --no-cache-dir --upgrade \
        "nvidia-ml-py>=12.560.30" \
        "fastapi[standard]>=0.115.0" \
        "optree>=0.13.0" \
        "pydantic>=2.9" \
        "grpcio>=1.62.1"

# ---------- upstream verl v0.4.0 (no-deps to keep our torch/vllm/ray pins) ----------
RUN pip install --no-cache-dir --no-deps \
    "verl @ git+https://github.com/volcengine/verl.git@v0.4.0"

# ==========================================================
# TeleBoost overlay (Wan + reward stack on top of the verl-compatible base)
# ==========================================================

# ---------- TeleBoost-specific deps ----------
# wan.modules.*  : easydict + diffusers
# videoclip      : opencv-python
# videophy       : decord
# hps            : hpsv2 + ftfy
# shared         : timm + einops
RUN pip install --no-cache-dir \
        diffusers==0.37.1 \
        easydict==1.13 \
        opencv-python==4.13.0.92 \
        decord==0.6.0 \
        ftfy==6.3.1 \
        einops==0.8.2 \
        timm==1.0.26 \
        hpsv2==1.2.0

# ---------- hpsv2 packaging fixes (see docs/install_from_scratch.md §3.1) ----------
# 1. The published wheel ships without the BPE vocab.
RUN VOCAB_DIR=$(python -c "import hpsv2.src.open_clip as m, os; print(os.path.dirname(m.__file__))") && \
    curl -fsSL -o "$VOCAB_DIR/bpe_simple_vocab_16e6.txt.gz" \
        https://raw.githubusercontent.com/tgxs002/HPSv2/master/hpsv2/src/open_clip/bpe_simple_vocab_16e6.txt.gz
# 2. factory.py has a stray `from turtle import forward` line — strip it.
RUN FACTORY=$(python -c "import hpsv2.src.open_clip.factory as m; print(m.__file__)") && \
    sed -i '/from turtle import forward/d' "$FACTORY"

# ---------- copy the TeleBoost source and install in editable mode ----------
WORKDIR /workspace/TeleBoost
COPY . /workspace/TeleBoost
RUN pip install --no-cache-dir --no-deps -e .

# ---------- reset pip mirror config so users picking up this image don't inherit it ----------
RUN pip config unset global.index-url || true && \
    pip config unset global.extra-index-url || true

# ---------- build-time self-check ----------
RUN python - <<'PY'
import torch, vllm, flash_attn, transformers, cv2, verl
from wan.modules.t5 import T5EncoderModel  # noqa: F401
from recipe.teleboost.reward_models import RewardRegistry
from hpsv2.src.open_clip import create_model_and_transforms  # noqa: F401
from decord import VideoReader  # noqa: F401
print(f"torch={torch.__version__}  vllm={vllm.__version__}  flash_attn={flash_attn.__version__}")
print(f"transformers={transformers.__version__}  cv2={cv2.__version__}  verl={verl.__version__}")
print(f"reward models: {RewardRegistry.list_available()}")
print("OK")
PY

# ---------- runtime env ----------
# TORCH_COMPILE_DISABLE=1: the Wan VAE decoder triggers torch._dynamo /
# inductor compilation, and on first run with a fresh cache the autotune
# JSON cache can race-corrupt across the 8 ranks (JSONDecodeError "Extra
# data" inside ``codecache._read``).  Eager mode side-steps the cache
# entirely and the perf hit on VAE decode is small (decode is not the
# bottleneck).  Override at run-time if you have a warmed cache.
ENV PYTHONPATH=/workspace/TeleBoost:${PYTHONPATH:-} \
    HYDRA_FULL_ERROR=1 \
    TOKENIZERS_PARALLELISM=false \
    TORCH_NCCL_AVOID_RECORD_STREAMS=1 \
    TORCH_COMPILE_DISABLE=1

CMD ["bash"]
