diff --git a/recipe/dancegrpo/config/dancegrpo_trainer.yaml b/recipe/dancegrpo/config/dancegrpo_trainer.yaml
index 4f2f1052..68db4e41 100644
--- a/recipe/dancegrpo/config/dancegrpo_trainer.yaml
